# Server-side secrets. DO NOT COMMIT. Copy to .env and fill in locally.
# On Vercel: Project Settings → Environment Variables.

# Password required to open /admin (default: admin123 — change this!)
ADMIN_PASSWORD=admin123

# Optional: a separate password that logs in as superadmin, unlocking the
# "Admins" panel (add/remove admins). Leave unset to disable superadmin.
SUPERADMIN_PASSWORD=

# 32+ char random string used to sign admin session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_SESSION_SECRET=replace-with-a-long-random-string
